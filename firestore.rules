rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Leaderboard collection: Anyone can read, only authenticated users can write.
    match /leaderboard/{email} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Chat Messages collection: Anyone can read and create.
    // Edit/delete requires matching userId (email for logged-in, session ID for guests).
    match /chat_messages/{messageId} {
      allow read: if true;
      allow create: if request.resource.data.text.size() > 0 && request.resource.data.text.size() <= 200;
      allow update, delete: if resource.data.userId == request.auth.uid || request.auth.uid == resource.data.userId || (!request.auth && resource.data.userId is string);
    }
  }
}
