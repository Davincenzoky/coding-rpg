rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Leaderboard collection: Anyone can read, only authenticated users can write.
    match /leaderboard/{email} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Chat Messages collection: Rate-limited to 1 message per 3 seconds per user.
    match /chat_messages/{messageId} {
      allow read: if true;
      allow create: if request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 200
        && request.resource.data.userId is string
        && request.resource.data.userId.size() > 0
        && (request.auth == null || request.auth.uid == request.resource.data.userId
            || request.auth.token.email == request.resource.data.userId);
    }
  }
}
